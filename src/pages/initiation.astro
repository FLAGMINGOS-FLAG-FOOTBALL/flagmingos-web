---
import Page from '../layouts/Page.astro'
import PageHeader from '../components/PageHeader.astro'
import PageContent from '../components/ui/PageContent.astro'
import SectionTitle from '../components/ui/SectionTitle.astro'
import Button from '../components/ui/Button.astro'
import Booking from '../components/Booking.astro'

import { getInitiationSessions } from '../lib/calendar'
const sessions = await getInitiationSessions()
---

<Page title="Initiation">
  <PageHeader
    eyebrow="READY TO PLAY?"
    title="ESSAIE LE"
    highlight="FLAG FOOTBALL"
    break={true}
    subtitle="Les Flagmingos organisent toute l'année des séances découverte ouvertes dès 9 ans, encadrées par des entraîneurs bénévoles diplômés. Un sport collectif mixte, ludique et accessible à tous. Viens essayer avant de t'engager."
    tags={['Dès 9 ans', 'Encadrement diplomé', 'Inscription gratuite', 'Mixte']}
    cta=`Une question ? <a href="/#contact" class="underline hover:text-brand-700 transition-colors">Contacte-nous</a> directement.`
  />
  <PageContent margin="small">
    {
      sessions.length === 0 ? (
        <>
          <SectionTitle
            title="AUCUNE"
            highlight="SÉANCE D'INITIATION"
            tagline="STEP ON THE FIELD"
            size="small"
            center={true}
          />

          <div class="h-4 md:h-8" />

          <p class="text-ink-soft mx-auto max-w-xl text-center text-sm leading-relaxed md:text-base">
            Aucune séance d'initiation n'est programmée pour le moment. Tu souhaites découvrir le
            flag football ? Contacte-nous et nous te proposerons la meilleure solution pour venir
            essayer.
          </p>

          <div class="mt-8 flex justify-center">
            <Button href="/#contact">Contacte-nous</Button>
          </div>
          <p class="text-ink-soft mx-auto mt-4 max-w-xl text-center text-sm">
            Nous répondons sous 24 heures.
          </p>
        </>
      ) : (
        <>
          <SectionTitle
            title="Inscris-toi à une"
            highlight="SÉANCE D'INITIATION"
            tagline="STEP ON THE FIELD"
            size="small"
            center={true}
          />
          <div class="h-4 md:h-8" />
          <Booking sessions={sessions} />
        </>
      )
    }
  </PageContent>
</Page>
