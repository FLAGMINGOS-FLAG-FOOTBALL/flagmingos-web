---
import Page from '../layouts/Page.astro'
import PageHeader from '../components/PageHeader.astro'
import PageContent from '../components/ui/PageContent.astro'
import Booking from '../components/Booking.astro'
---

<Page title="Initiation">
  <PageHeader
    eyebrow="READY TO PLAY?"
    title="ESSAIE LE"
    highlight="FLAG FOOTBALL"
    break={true}
    subtitle="Les Flagmingos organisent toute l'année des séances découverte ouvertes dès 9 ans, encadrées par des entraîneurs bénévoles diplômés. Un sport collectif mixte, ludique et accessible à tous. Viens essayer avant de t'engager."
    tags={['Dès 9 ans', 'Encadrement diplomé', 'Inscription gratuite', 'Mixte']}
    cta=`Une question ? <a href="/#contact" class="underline hover:text-brand-700 transition-colors">Contactez-nous</a> directement.`
  />
  <PageContent>
    <Booking />
  </PageContent>
</Page>
