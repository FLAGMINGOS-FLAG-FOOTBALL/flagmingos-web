---
import Page from '@layouts/Page.astro'
import PageHeader from '@ui/PageHeader.astro'
import PageContent from '@ui/PageContent.astro'
import Intro from '@components/flag/Intro.astro'
import Action from '@components/flag/Actions.astro'
import CtaInitiation from '@components/CtaInitiation.astro'
---

<Page
  title="Le Flag Football - Flagmingos"
  description="Découvre le Flag Football, un sport collectif sans contact, stratégique et accessible à toutes et tous. Que tu débutes ou que tu aies de l'expérience, viens vivre l'expérience Flagmingos."
>
  <PageHeader
    eyebrow="THE GAME"
    title="FLAG"
    highlight="FOOTBALL"
    break={false}
    subtitle="Découvre le Flag Football, un sport collectif sans contact, stratégique et accessible à toutes et tous. Que tu débutes ou que tu aies de l'expérience, viens vivre l’expérience Flagmingos."
  />
  <PageContent>
    <Intro />
  </PageContent>
  <Action />
  <PageContent>
    <CtaInitiation />
  </PageContent>
</Page>
