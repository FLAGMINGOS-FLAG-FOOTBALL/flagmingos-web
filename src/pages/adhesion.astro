---
import Page from '@layouts/Page.astro'
import PageHeader from '@ui/PageHeader.astro'
import PageContent from '@ui/PageContent.astro'
import SectionTitle from '@ui/SectionTitle.astro'
import Paragraph from '@ui/Paragraph.astro'
import LicenceCards from '@components/adhesion/LicenceCards.astro'
import Equipment from '@components/adhesion/Equipment.astro'
import Engagement from '@components/adhesion/Engagement.astro'
import CtaHelloasso from '@components/adhesion/CtaHelloasso.astro'
---

<Page
  title="Adhésion - Flagmingos"
  description="Rejoignez les Flagmingos : équipes compétition, féminine, jeunes et loisir. Choisissez votre section et adhérez pour la saison."
>
  <PageHeader
    eyebrow="BECOME A FLAGMINGO"
    title="REJOINS"
    highlight="L'AVENTURE"
    break={false}
    subtitle="Choisis la section qui te correspond et rejoins les Flagmingos pour une saison de flag football, de progression et de partage."
  />
  <PageContent>
    <SectionTitle title="TROUVE TON" highlight="ÉQUIPE" tagline="BECOME A FLAGMINGO" size="large" />
    <Paragraph>
      Que tu sois débutant ou compétiteur, jeune ou adulte, il y a une équipe pour toi. Découvre les
      différentes sections proposées par les Flagmingos et choisis celle qui te correspond le mieux.
    </Paragraph>
    <LicenceCards />
  </PageContent>
  <Equipment />
  <PageContent>
    <SectionTitle
      title="IMPLIQUE TOI,"
      highlight="ÉCONOMISE"
      tagline="Club benefits"
      size="medium"
    />
    <Paragraph> Aux Flagmingos, ton engagement dans la vie du club est valorisé. </Paragraph>
    <Engagement />
  </PageContent>
  <PageContent noBackground={true}>
    <CtaHelloasso />
  </PageContent>
</Page>
