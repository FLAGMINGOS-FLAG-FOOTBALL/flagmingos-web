---
import { email, phone, address, instagram, jsonld } from '../params.json'
const { streetAddress, postalCode, addressLocality, foundingDate } = jsonld

interface Props {
  title: string
  description: string
  ogImage?:  ImageMetadata
}

const { title, description, ogImage } = Astro.props

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString()
const resolvedOgImage = new URL(ogImage?.src ?? '/og-default.jpg', Astro.site).toString()

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsClub',
  name: 'Flagmingos',
  url: Astro.site?.toString(),
  logo: new URL('/android-chrome-512x512.png', Astro.site).toString(),
  image: resolvedOgImage,
  email,
  telephone: phone,
  foundingDate,
  address: {
    '@type': 'PostalAddress',
    streetAddress,
    postalCode,
    addressLocality,
    addressCountry: 'FR',
  },
  sameAs: [`https://instagram.com/${instagram}`],
  sport: 'Flag Football',
}
---

<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={resolvedOgImage} />
{
  ogImage && (
    <>
      <meta property="og:image:width" content={ogImage.width.toString()} />
      <meta property="og:image:height" content={ogImage.height.toString()} />
    </>
  )
}
<meta property="og:locale" content="fr_FR" />
<meta property="og:site_name" content="Flagmingos" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
