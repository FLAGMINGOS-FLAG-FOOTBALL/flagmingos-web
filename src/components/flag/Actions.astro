---
const steps = [
  {
    n: '01',
    title: "L'engagement",
    desc: 'Chaque action commence par un snap. Le centre transmet le ballon au quarterback, qui choisit de passer ou courir.',
  },
  {
    n: '02',
    title: 'La progression',
    desc: "L’équipe attaquante dispose de plusieurs tentatives pour avancer sur le terrain, par la passe ou la course, et atteindre la zone d’en-but.",
  },
  {
    n: '03',
    title: 'Le retrait du flag',
    desc: "Dès que la défense retire le flag du porteur, l'action s'arrête immédiatement - comme un tacle, mais sans contact.",
  },
  {
    n: '04',
    title: 'Le score',
    desc: 'Un touchdown rapporte 6 points, suivi d’une tentative de transformation pour 1 ou 2 points supplémentaires.',
  },
]
---

<section class="bg-brand-800 py-14 text-white md:py-20">
  <div class="mx-auto max-w-295 px-5 md:px-10">
    <div class="mb-10 text-center md:mb-12">
      <div class="text-brand-500 mb-3 font-mono text-xs tracking-[0.15em]">HOW IT WORKS</div>
      <h2 class="font-display text-[clamp(28px,6vw,44px)] leading-none uppercase">
        Le déroulé d'une action
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s) => (
          <div class="hover:border-brand-500 relative overflow-hidden border-2 border-white/15 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl">
            <div class="font-display pointer-events-none absolute -top-4 -right-4 -skew-x-6 text-[120px] leading-none opacity-5 select-none">
              {s.n}
            </div>
            <div class="font-display mb-2 text-2xl uppercase">{s.title}</div>
            <p class="text-sm leading-relaxed text-[#B9B5AE]">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
