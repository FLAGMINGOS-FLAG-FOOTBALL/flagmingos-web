---
import RightArrow from '@lucide/astro/icons/arrow-right'

interface Props {
  current?: 1 | 2 | 3
  dark?: boolean
}
const { dark = false } = Astro.props as Props

const steps = [
  {
    tag: 'TRY',
    title: 'Premiers pas',
    desc: 'Découvre le flag football lors d’une séance gratuite, sans engagement.',
    bullets: ['2h de découverte', 'Matériel prêté', 'Débutants bienvenus'],
    badge: 'Gratuit',
    href: '/initiation',
    cta: 'Je découvre le flag',
  },
]

const initiation = {
  tag: 'TRY FLAG',
  title: 'Premiers pas',
  desc: 'Découvre le flag football lors d’une séance gratuite, sans engagement.',
  bullets: ['Séance découverte', 'Matériel fourni', 'Ouvert aux débutants'],
  href: '/initiation',
  cta: 'Je découvre le Flag',
}
---

<section class={dark ? 'bg-brand-800 text-white' : ''}>
  <div class="mx-auto max-w-295 px-5 md:px-10">
    <div class="text-center mb-10 md:mb-12">
      <div
        class={`font-mono text-xs tracking-[0.15em] mb-3 ${dark ? 'text-brand-500' : 'text-brand-700'}`}
      >
        JOIN THE FLAMBOYANCE
      </div>
      <h2
        class="font-display uppercase text-[clamp(32px,6vw,56px)] leading-none"
      >
        Viens essayer
      </h2>
      <p
        class={`mt-4 max-w-xl mx-auto text-base ${dark ? 'text-brand-50/80' : 'text-ink-soft'}`}
      >
        Ton premier entraînement de flag football est gratuit. Il suffit de
        venir jouer.
      </p>
    </div>

    <div class="max-w-xl mx-auto">
      {
        steps.map((s) => {
          const borderClass = dark ? 'border-white/15' : 'border-line'
          return (
            <div
              class={`${borderClass} relative border-2 p-6 md:p-7 flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:border-brand-500 hover:shadow-2xl`}
            >
              <div
                class={`font-mono text-[11px] font-bold tracking-wide mb-2 ${dark ? 'text-brand-500' : 'text-brand-700'}`}
              >
                {s.tag}
              </div>
              <div class="font-display uppercase text-2xl mb-2">{s.title}</div>
              <p
                class={`text-sm leading-relaxed mb-5 flex-1 ${dark ? 'text-brand-50/80' : 'text-ink-soft'}`}
              >
                {s.desc}
              </p>
              <ul class="space-y-2 mb-8">
                {s.bullets.map((item) => (
                  <li class="text-sm opacity-80 flex gap-2">
                    <span class="text-brand-500">•</span>
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href={s.href}
                class={`inline-flex items-center gap-1.5 text-sm font-bold ${dark ? 'hover:text-brand-500' : 'hover:text-brand-700'} transition-colors w-fit`}
              >
                {s.cta} {<RightArrow class="w-4 h-4" />}
              </a>
            </div>
          )
        })
      }
    </div>
  </div>
</section>
