---
import RightArrow from '@lucide/astro/icons/arrow-right'

const targetDate = '2026-08-25T20:00:00'
const endDate = '2026-09-13T20:00:00'
const openHouseStart = '25 août'
const openHouseEnd = '13 septembre'

const units = [
  { id: 'cd-days', label: 'Jours' },
  { id: 'cd-hours', label: 'Heures' },
  { id: 'cd-minutes', label: 'Min' },
  { id: 'cd-seconds', label: 'Sec' },
]
---

<div
  id="season-countdown-banner"
  class="bg-brand-500 relative overflow-hidden px-6 py-10 text-white"
>
  <div class="bg-brand-500 relative mx-auto flex flex-col justify-around gap-x-10 lg:flex-row">
    <div id="season-title" class="text-center lg:text-left">
      <div class="mb-4 font-mono text-xs tracking-[0.15em] text-white/80">SAISON 2026-2027</div>
      <h2
        class="font-display -skew-x-6 text-[clamp(32px,9vw,64px)] leading-none text-white uppercase"
      >
        BACK TO FLAG
      </h2>

      <div id="season-upcoming" class="mx-auto mt-4 max-w-xl text-base text-white">
        La saison 2026-2027 commence le {openHouseStart}. Rejoins-nous pour ton premier
        entraînement. Portes Ouvertes du {openHouseStart} au {openHouseEnd}.
        <p class="mt-3 items-center gap-2 text-sm text-white/80">
          Pas envie d'attendre août ?
          <a
            href="/initiation"
            class="inline-flex items-center justify-center gap-1.5 px-0 py-0 text-sm font-bold text-white transition-colors hover:text-white/80"
          >
            Viens essayer dès maintenant
            <RightArrow class="h-4 w-4" />
          </a>
        </p>
      </div>

      <div id="season-started" class="mx-auto mt-4 hidden text-base text-white">
        La saison est lancée ! Les Portes Ouvertes continuent jusqu'au {openHouseEnd} — viens essayer,
        aucun engagement requis.
        <p class="mt-3 text-sm text-white/80">
          <a
            href="/initiation"
            class="inline-flex items-center justify-center gap-1.5 px-0 py-0 text-sm font-bold text-white transition-colors hover:text-white/80"
          >
            Rejoins nous dès maintenant
            <RightArrow class="h-4 w-4" />
          </a>
        </p>
      </div>
    </div>

    <div id="season-countdown-timer" class="flex items-center justify-center gap-2.5 text-center pt-10 lg:pt-0">
      {
        units.map((u) => (
          <div class="min-w-20 -skew-x-3 md:min-w-24">
            <div class="mx-auto flex flex-col items-center justify-center">
              <div
                id={u.id}
                class="text-brand-700 font-display w-[2ch] text-7xl font-extrabold tabular-nums lg:text-9xl"
              >
                00
              </div>
              <div class="mt-1 text-[10px] font-semibold tracking-wide text-white/80 uppercase md:text-xs">
                {u.label}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script define:vars={{ targetDate, endDate }}>
  const target = new Date(targetDate).getTime()
  const endDay = new Date(endDate).getTime()
  const banner = document.getElementById('season-countdown-banner')
  const timer = document.getElementById('season-countdown-timer')
  const bannerUpcoming = document.getElementById('season-upcoming')
  const bannerStarted = document.getElementById('season-started')

  if (endDay < Date.now()) {
    banner?.classList.add('hidden')
  }

  let switched = false

  function switchToStarted() {
    if (switched) return
    switched = true
    timer?.classList.add('hidden')
    document.getElementById('season-title')?.classList.remove('lg:text-left')
    bannerUpcoming?.classList.add('hidden')
    bannerStarted?.classList.remove('hidden')
  }

  function tick() {
    const now = Date.now()
    const diff = target - now
    const diffEnd = endDay - now

    if (diff <= 0) {
      switchToStarted()
      return
    }

    if (diffEnd <= 0) {
      hideAfterEnd()
      return
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24))
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24)
    const minutes = Math.floor((diff / (1000 * 60)) % 60)
    const seconds = Math.floor((diff / 1000) % 60)

    const set = (id, value) => {
      const el = document.getElementById(id)
      if (el) el.textContent = String(value).padStart(2, '0')
    }

    set('cd-days', days)
    set('cd-hours', hours)
    set('cd-minutes', minutes)
    set('cd-seconds', seconds)
  }

  tick()
  const interval = setInterval(tick, 1000)
</script>
