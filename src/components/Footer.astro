---
import Logotype from './ui/Logotype.astro'
import FooterTitle from './ui/FooterTitle.astro'
import Signature from './ui/Signature.astro'
import { address, email, phone } from '../params.json'

const navLinks = [
  {
    name: 'Accueil',
    href: '/',
  },
  {
    name: 'Équipes',
    href: '#equipe',
  },
  {
    name: 'Calendrier',
    href: '#calendrier',
  },
  {
    name: 'Contact',
    href: '#contact',
  },
]

const socials = [
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/flagmingos/',
  },
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/flagmingos/',
  },
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/company/flagmingos/',
  },
  {
    name: 'TikTok',
    href: 'https://www.tiktok.com/@flagmingos',
  },
]
---

<footer class="bg-brand-800 text-white overflow-hidden">
  <div class="container mx-auto block relative h-full p-6 max-w-295">
    <div
      class="flex flex-col md:flex-row md:items-center justify-between gap-4 pb-7 md:pb-8 border-b border-brand-50/50"
    >
      <div class="font-display uppercase text-2xl md:text-3xl leading-tight tracking-wide -skew-x-6 py-2">
        TOGETHER WE FLY HIGH
      </div>
    </div>
    <nav
      class="flex flex-wrap justify-center md:justify-between gap-x-8 gap-y-3 text-sm font-semibold border-b border-brand-50/50 py-6 md:py-7"
    >
      {
        navLinks.map((link) => (
          <a href={link.href} class="hover:text-brand-500 transition-colors">
            {link.name}
          </a>
        ))
      }
    </nav>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 py-10 md:py-14">
      <div class="flex flex-col gap-3">
        <Logotype />
        <p class="text-sm text-brand-50/80">
          Association sportive à but non lucratif, reconnue d’intérêt général et
          affiliée à la Fédération Française de Football Américain.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        <FooterTitle title="Email" />
        <a
          href={`mailto:${email}`}
          class="text-brand-50/80 text-sm hover:text-brand-500 transition-colors mb-3"
        >
          {email}
        </a>
        <FooterTitle title="Téléphone" />
        <a
          href={`tel:${phone}`}
          class="text-brand-50/80 text-sm hover:text-brand-500 transition-colors"
        >
          {phone}
        </a>
      </div>
      <div class="flex flex-col gap-3">
        <FooterTitle title="Venir au stade" />
        <p
          class="text-brand-50/80 text-sm"
          set:html={address.replace(',', '<br />')}
        />
        <a
          href="https://goo.gl/maps/?q=Flagmingos%20Flag%20Football"
          class="text-brand-50/80 hover:text-brand-400 transition-colors text-sm"
          >Google Maps &#8599;</a
        >
        <a
          href="https://maps.apple.com/?q=Flagmingos%20Flag%20Football"
          class="text-brand-50/80 hover:text-brand-400 transition-colors text-sm"
          >Apple Plan &#8599;</a
        >
      </div>
      <div>
        <div class="font-display uppercase text-lg tracking-wide mb-4">
          Suivez-nous
        </div>
        <ul class="space-y-3">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="inline-flex items-center gap-1.5 text-brand-50/80 text-sm hover:text-brand-500 transition-colors"
                >
                  {s.name} <span aria-hidden="true">&#8599;</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div
      class="flex flex-col-reverse md:flex-row items-center md:items-center justify-between gap-3 border-t border-brand-50/50 py-6 text-xs text-brand-50/80"
    >
      <div>
        © {new Date().getFullYear()} Flagmingos. Tous droits réservés.
      </div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-brand-50 transition-colors"
          >Mentions légales</a
        >
      </div>
    </div>
  </div>
  <Signature color="text-brand-50/20" />
  <div
    class="relative z-0 select-none pointer-events-none font-display uppercase text-brand-500/60 leading-[0.8] text-center translate-y-[28%] -skew-x-6 text-[20vw]"
    aria-hidden="true"
  >
    FLAGMINGOS
  </div>
</footer>
