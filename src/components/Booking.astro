---
import ButtonForm from './ui/ButtonForm.astro'
// Séances à venir — à tenir à jour manuellement ou brancher sur une source de données.
const sessions = [
  'Mardi 30 juin 2026 — 19h-22h — Parc de Lagarde (Adultes, mixte)',
  'Jeudi 2 juillet 2026 — 20h-22h — Parc de Lagarde (Adultes, mixte)',
  'Mardi 7 juillet 2026 — 19h-22h — Parc de Lagarde (Adultes, mixte)',
  'Jeudi 9 juillet 2026 — 20h-22h — Parc de Lagarde (Adultes, mixte)',
]
---

<section>
  <div class="mx-auto max-w-180 px-5 md:px-10">
    <div class="bg-white border border-line p-6 md:p-9">
      <form
        id="booking-form"
        name="initiation"
        data-netlify="true"
        netlify-honeypot="bot-field"
        method="POST"
        class="space-y-5"
      >
        <input type="hidden" name="form-name" value="initiation" />
        <p class="hidden">
          <label>
            Don't fill this out if you're human:
            <input name="bot-field" />
          </label>
        </p>
        <div>
          <label
            for="session"
            class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5"
          >
            Séance choisie
          </label>
          <select
            id="session"
            name="session"
            required
            class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm bg-white transition-colors"
          >
            <option value="" disabled selected>Choisir une date</option>
            {sessions.map((s) => <option value={s}>{s}</option>)}
          </select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label
              for="lastname"
              class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5"
              >Nom</label
            >
            <input
              type="text"
              id="lastname"
              name="lastname"
              required
              class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm transition-colors"
            />
          </div>
          <div>
            <label
              for="firstname"
              class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5"
              >Prénom</label
            >
            <input
              type="text"
              id="firstname"
              name="firstname"
              required
              class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm transition-colors"
            />
          </div>
        </div>

        <div>
          <label
            for="birthdate"
            class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5"
            >Date de naissance</label
          >
          <input
            type="date"
            id="birthdate"
            name="birthdate"
            required
            class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm transition-colors"
          />
        </div>

        <div id="parent-field" class="hidden">
          <label
            for="parentname"
            class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5"
          >
            Nom / Prénom du parent <span
              class="normal-case font-sans text-ink-soft"
              >(obligatoire pour les 9-17 ans)</span
            >
          </label>
          <input
            type="text"
            id="parentname"
            name="parentname"
            required
            class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm transition-colors"
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label
              for="phone"
              class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5"
              >Téléphone</label
            >
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm transition-colors"
            />
          </div>
          <div>
            <label
              for="email"
              class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5"
              >E-mail</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm transition-colors"
            />
          </div>
        </div>

        <!-- <div>
          <label for="address" class="block font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-1.5">Adresse</label>
          <input
            type="text" id="address" name="address"
            class="w-full border-2 border-line focus:border-brand-500 outline-none px-3.5 py-2.5 text-sm transition-colors"
          />
        </div> -->

        <fieldset class="border-2 border-line p-4">
          <legend
            class="font-mono text-[11px] uppercase tracking-wide text-ink-soft px-1"
            >Communication du club</legend
          >
          <label class="flex items-start gap-2.5 text-sm cursor-pointer">
            <input
              type="radio"
              name="communication"
              value="accepte"
              class="mt-1 accent-brand-500"
              checked
            />
            J'accepte de recevoir les communications du club (actualités, initiations,
            promotions...) par e-mail et/ou SMS.
          </label>
          <label class="flex items-start gap-2.5 text-sm mt-2.5 cursor-pointer">
            <input
              type="radio"
              name="communication"
              value="refuse"
              class="mt-1 accent-brand-500"
            />
            Je n'accepte pas de recevoir les communications du club.
          </label>
        </fieldset>

        <label class="flex items-start gap-2.5 text-sm cursor-pointer">
          <input
            type="checkbox"
            name="privacy-consent"
            required
            class="mt-1 accent-brand-500"
          />

          <span>
            J'accepte que mes données soient utilisées uniquement pour gérer mon
            inscription à la séance d'initiation.

            <a
              href="/mentions-legales#donnees-personnelles"
              class="underline hover:text-brand-700"
            >
              En savoir plus</a>.
          </span>
        </label>

        <!-- <p class="font-mono text-[11px] text-ink-soft">
          Les informations recueillies sont nécessaires à l’organisation de
          votre séance d'initiation et ne seront utilisées que dans ce cadre.
        </p> -->
        <div data-netlify-recaptcha="true"></div>

        <ButtonForm
          type="submit"
          class="w-full"
          id="booking-submit-button"
          icon="arrow-right"
        >
          Je découvre le flag
        </ButtonForm>

        <p id="booking-status" class="text-sm text-center hidden" role="status">
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement | null
  const status = document.getElementById('booking-status')
  const submitLabel = document.getElementById('booking-submit-label')
  const button = form?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement | null
  const birthdate = document.getElementById(
    'birthdate',
  ) as HTMLInputElement | null
  const parentField = document.getElementById('parent-field')
  const parentInput = document.getElementById(
    'parentname',
  ) as HTMLInputElement | null

  function toggleParentField() {
    if (!birthdate?.value || !parentField) return
    const dob = new Date(birthdate.value)
    const age = (Date.now() - dob.getTime()) / (1000 * 60 * 60 * 24 * 365.25)

    if (age < 18) {
      parentField.classList.remove('hidden')
      parentInput?.setAttribute('required', 'true')
    } else {
      parentField.classList.add('hidden')
      parentInput?.removeAttribute('required')
    }
  }

  birthdate?.addEventListener('change', toggleParentField)

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form || !status || !submitLabel || !button) return

    button.disabled = true
    submitLabel.textContent = 'Envoi en cours...'
    status.classList.add('hidden')

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      })

      if (response.ok) {
        form.reset()
        parentField?.classList.add('hidden')
        status.textContent =
          'Inscription envoyée ! On revient vers vous rapidement.'
        status.className = 'text-sm text-center text-win'
      } else {
        throw new Error('Request failed')
      }
    } catch {
      status.textContent =
        'Un souci est survenu. Contactez-nous directement en attendant.'
      status.className = 'text-sm text-center text-brand-700'
    } finally {
      status.classList.remove('hidden')
      button.disabled = false
      submitLabel.textContent = 'Réserver ma place'
    }
  })
</script>
