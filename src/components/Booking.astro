---
import CalendarCheck from '@lucide/astro/icons/calendar-check'
import Calendar from '@lucide/astro/icons/calendar'
import ButtonForm from './ui/ButtonForm.astro'
import ModalForm from './ui/ModalForm.astro'
interface props {
  sessions: Event[]
}

const { sessions } = Astro.props as props

import { formatDate, formatTime, formatDateDisplay, type Event } from '../lib/calendar'
---

<section>
  <div class="mx-auto max-w-180 px-5 md:px-10">
    <div class="border-line border bg-white p-6 md:p-9">
      <form
        id="booking-form"
        name="initiation"
        data-netlify="true"
        netlify-honeypot="bot-field"
        method="POST"
        class="space-y-5"
      >
        <input type="hidden" name="form-name" value="initiation" />
        <p class="hidden">
          <label>
            Don't fill this out if you're human:
            <input name="bot-field" />
          </label>
        </p>
        <label
          for="session"
          class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
        >
          Séance choisie
        </label>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            sessions.slice(0, 4).map((s) => (
              <label class="group border-line has-checked:border-brand-500 has-checked:bg-brand-50 flex items-center justify-between border-2 bg-white p-5 transition">
                <input
                  type="radio"
                  name="session"
                  class="peer sr-only"
                  required
                  value={formatDate(s.startDate)}
                />

                <div>
                  <p class="text-ink font-semibold">{formatDateDisplay(s.startDate)}</p>

                  <p class="text-ink-soft mt-2 font-mono text-sm">
                    {formatTime(s.startDate)} — {formatTime(s.endDate)}
                  </p>
                </div>
                <Calendar class="text-line 00 h-6 w-6 transition group-has-checked:hidden" />
                <CalendarCheck class="text-line group-has-checked:text-brand-500 hidden h-6 w-6 transition group-has-checked:block" />
              </label>
            ))
          }
        </div>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label
              for="lastname"
              class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >
              Nom
            </label>
            <input
              type="text"
              id="lastname"
              name="lastname"
              required
              class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
            />
          </div>
          <div>
            <label
              for="firstname"
              class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >
              Prénom
            </label>
            <input
              type="text"
              id="firstname"
              name="firstname"
              required
              class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
            />
          </div>
        </div>

        <div>
          <label
            for="birthdate"
            class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
          >
            Date de naissance
          </label>
          <input
            type="date"
            id="birthdate"
            name="birthdate"
            required
            class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
          />
        </div>

        <div id="parent-field" class="hidden">
          <label
            for="parentname"
            class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
          >
            Nom / Prénom du parent
            <span class="text-ink-soft font-sans normal-case">
              (obligatoire pour les 9-17 ans)
            </span>
          </label>
          <input
            type="text"
            id="parentname"
            name="parentname"
            class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
          />
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label
              for="phone"
              class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >
              Téléphone
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
            />
          </div>
          <div>
            <label
              for="email"
              class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >
              E-mail
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
            />
          </div>
        </div>

        <fieldset class="border-line border-2 p-4">
          <legend class="text-ink-soft px-1 font-mono text-[11px] tracking-wide uppercase">
            Communication du club
          </legend>
          <label class="flex cursor-pointer items-start gap-2.5 text-sm">
            <input
              type="radio"
              name="communication"
              value="accepte"
              class="accent-brand-500 mt-1"
              checked
            />
            J'accepte de recevoir les communications du club (actualités, initiations, promotions...)
            par e-mail et/ou SMS.
          </label>
          <label class="mt-2.5 flex cursor-pointer items-start gap-2.5 text-sm">
            <input type="radio" name="communication" value="refuse" class="accent-brand-500 mt-1" />
            Je n'accepte pas de recevoir les communications du club.
          </label>
        </fieldset>

        <label class="flex cursor-pointer items-start gap-2.5 text-sm">
          <input type="checkbox" name="privacy-consent" required class="accent-brand-500 mt-1" />

          <span>
            J'accepte que mes données soient utilisées uniquement pour gérer mon inscription à la
            séance d'initiation.
            <a href="/mentions-legales#donnees-personnelles" class="hover:text-brand-700 underline">
              En savoir plus
            </a>
            .
          </span>
        </label>

        {
          /* <!-- <p class="font-mono text-[11px] text-ink-soft">
          Les informations recueillies sont nécessaires à l’organisation de
          votre séance d'initiation et ne seront utilisées que dans ce cadre.
        </p> --> */
        }
        <div data-netlify-recaptcha="true"></div>

        <ButtonForm type="submit" class="w-full" id="booking-submit-button" icon="arrow-right">
          Je découvre le flag
        </ButtonForm>

        <p id="booking-status" class="hidden text-center text-sm" role="status"></p>
      </form>
    </div>
  </div>
  <!-- <button id="test-button" class="block" type="button"> Test modal </button> -->
  <ModalForm id="success-modal-booking" football title="Inscription réussie !">
    Ton inscription est dans nos mains.<br />On se retrouve sur le terrain !
  </ModalForm>
  <ModalForm id="error-modal-booking" variant="error" title="Oups !">
    Une erreur est survenue lors de l'envoi du formulaire.<br />Merci de réessayer plus tard ou de nous <a href="/#contact" class="hover:text-brand-700 underline">contacter</a> directement.
  </ModalForm>
</section>

<script>
  import { submitForm } from '../lib/form'
  submitForm('booking-form', 'success-modal-booking', 'error-modal-booking')

  const birthdateInput = document.getElementById('birthdate') as HTMLInputElement
  const parentField = document.getElementById('parent-field')
  const parentName = document.getElementById('parentname') as HTMLInputElement

  birthdateInput?.addEventListener('change', () => {
    const birthdateValue = birthdateInput.value
    if (birthdateValue) {
      const birthdate = new Date(birthdateValue)
      const today = new Date()
      const age = today.getFullYear() - birthdate.getFullYear()
      if (age < 18) {
        parentField?.classList.remove('hidden')
        parentName.required = true
      } else {
        parentField?.classList.add('hidden')
        parentName.required = false
      }
    }
  })
</script>