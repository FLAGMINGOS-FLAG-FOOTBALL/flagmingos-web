---
import Button from '@ui/Button.astro'
import SectionTitle from '@ui/SectionTitle.astro'
import { HELLOASSO_URL } from '@data/adhesion'
---

<section>
  <div class="mx-auto max-w-180 text-center">
    <SectionTitle title="Prêt à rejoindre
      les Flagmingos ?" tagline="JOIN THE FLAMBOYANCE" />

    <p class="text-md text-ink-soft mx-auto leading-relaxed">
      Ton inscription se fait simplement en ligne via HelloAsso. En seulement quelques étapes et les
      documents nécessaires, tu fais officiellement partie des Flagmingos.
    </p>

    <!-- DOCUMENTS -->

    <div class="bg-brand-50 border-brand-100 mt-7 inline-block border px-6 py-5 text-left">
      <p class="text-brand-700 mb-4 font-mono text-[11px] tracking-wide uppercase">
        Documents nécessaires
      </p>

      <ul class="text-ink-soft space-y-3 text-sm">
        <li class="flex gap-3">
          <span class="text-brand-500 font-bold">01</span>
          <span>
            Certificat médical mentionnant « pas de contre-indication à la pratique du Flag Football
            en compétition »
          </span>
        </li>

        <li class="flex gap-3">
          <span class="text-brand-500 font-bold">02</span>
          <span> Photo d'identité récente </span>
        </li>
      </ul>
    </div>

    <!-- CTA -->

    <div class="mt-8">
      <Button href={HELLOASSO_URL}> Prendre ma licence </Button>
    </div>

    <p class="text-ink-soft mt-4 text-xs">Paiement sécurisé via HelloAsso</p>
  </div>
</section>
