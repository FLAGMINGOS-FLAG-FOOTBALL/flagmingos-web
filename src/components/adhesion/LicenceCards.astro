---
import Tagline from '../ui/Tagline.astro'
import Button from '../ui/Button.astro'
import { sections } from '../../data/adhesion'
import Plus from '@lucide/astro/icons/plus'
---

<div class="grid gap-6 lg:grid-cols-3 my-12">
  {
    sections.map((section) => (
      <article
        class={`
          relative flex flex-col border-2 p-6
          ${section.primary ? 'border-brand-500 bg-brand-50' : 'border-line bg-white'}
        `}
      >

        <!-- Catégorie -->

        <Tagline text={section.tag} />


        <!-- Nom -->

        <h3 class="font-display text-3xl uppercase text-ink leading-none">
          {section.title}
        </h3>


        <!-- Accroche -->

        <p class="mt-3 text-sm font-bold text-brand-700">
          {section.highlight}
        </p>


        <!-- Description -->

        <p class="mt-4 text-sm text-ink-soft leading-relaxed">
          {section.description}
        </p>


        <!-- Infos -->

        <div class="mt-8 border-t border-line pt-5 space-y-5">


          <!-- Public -->

          <div>
            <p class="font-mono text-xs uppercase text-ink-soft">
              Public
            </p>

            <p class="mt-1 text-sm font-semibold">
              {section.public}
            </p>
          </div>


          <!-- Entrainements -->

          {/* {
            section.trainings && (
              <div>
                <p class="font-mono text-xs uppercase text-ink-soft mb-2">
                  Entraînements
                </p>

                <ul class="space-y-1">
                  {
                    section.trainings.map((training) => (
                      <li class="text-sm">
                        <span class="text-brand-500">+</span> {training.group}
                      </li>
                    ))
                  }
                </ul>
              </div>
            )
          } */}


          <!-- Tarif -->

          <div>
            <p class="font-mono text-xs uppercase text-ink-soft">
              Licence annuelle
            </p>

            <p class="mt-1 font-display text-4xl text-ink leading-none">
              {section.price}€
            </p>

            {
              section.femalePrice && (
                <p class="text-sm font-bold text-brand-700 mt-1">
                  {section.femalePrice}€ féminines et étudiants*
                </p>
                <p class="text-[11px] text-ink-soft mt-1">
                  *Tarif réduit pour les étudiants sur présentation d’un justificatif.
                </p>
              )
            }
          </div>

        </div>


        <!-- Points forts -->

        {
          section.details && (
            <ul class="mt-6 border-t border-line pt-5 space-y-2">
              {
                section.details.map((detail) => (
                  <li class="text-sm text-ink-soft">
                    <span class="text-brand-500">+</span> {detail}
                  </li>
                ))
              }
            </ul>
          )
        }
      </article>
    ))
  }
</div>
<div class="grid gap-6 md:grid-cols-2">

    <div class="border-2 border-line bg-white p-6">
        <div
        class="font-mono text-xs uppercase tracking-[0.15em] text-brand-700 mb-4"
        >
          À SAVOIR
        </div>

        <div class="space-y-4 text-sm text-ink-soft leading-relaxed">
          <p>
            <strong class="text-ink">U7 à U18 :</strong>

            <br />

            Les inscriptions sont validées par les entraîneurs afin de garantir
            un accueil adapté.
          </p>
          
          <p>
              <strong class="text-ink">Surclassement :</strong>

              <br />

              Les joueurs nés en 2009 souhaitant évoluer en catégorie séniors
            doivent obtenir une validation préalable.
          </p>
        </div>
    </div>
    <div class="border-2 border-line bg-white p-6">
        <div
        class="font-mono text-xs uppercase tracking-[0.15em] text-brand-700 mb-4"
        >
        AIDE FINANCIÈRE
        </div>

        <div class="space-y-4 text-sm text-ink-soft leading-relaxed">
            <div class="text-ink font-display uppercase leading-none text-2xl">LE PASS'SPORT</div>
          <p>Une aide financière de l'État pour la pratique sportive, déductible directement de votre cotisation.</p>
          <Button variant="secondary" size="small" href="https://www.sports.gouv.fr/pass-sport-une-aide-financiere-la-pratique-sportive-295" target="_blank" rel="noopener noreferrer">
            En savoir plus
          </Button>
          
        </div>
    </div>
</div>