---
import Football from '@icons/football.astro'
import Check from '@lucide/astro/icons/check'
import X from '@lucide/astro/icons/x'

interface Props {
  id: string
  variant?: 'success' | 'error' | 'info'
  eyebrow?: string
  title?: string
  description?: string
  football?: boolean
  button?: string
  debug?: boolean
}

const {
  id,
  variant = 'success',
  eyebrow,
  title,
  description,
  football = false,
  button = 'Fermer',
  debug = false,
} = Astro.props as Props

const contentId = `${id}-content`
const titleId = `${id}-title`

const variants = {
  success: {
    icon: 'check',
    color: 'text-brand-500',
    bg: 'bg-brand-500',
    defaultEyebrow: 'PASS COMPLETE',
    defaultTitle: 'Message envoyé !',
  },
  error: {
    icon: 'x',
    color: 'text-red-500',
    bg: 'bg-red-500',
    defaultEyebrow: 'PASS INCOMPLETE',
    defaultTitle: 'Une erreur est survenue',
  },
  info: {
    icon: 'check',
    color: 'text-brand-500',
    bg: 'bg-brand-500',
    defaultEyebrow: 'HUDDLE UPDATE',
    defaultTitle: 'Information',
  },
}

const current = variants[variant]
---

<div
  id={id}
  class={`fixed inset-0 z-50 ${debug ? 'flex opacity-100' : 'hidden opacity-0'} items-center justify-center bg-black/60 px-5 backdrop-blur-sm transition-opacity duration-300`}
  role="dialog"
  aria-modal="true"
  aria-labelledby={titleId}
  aria-describedby={contentId}
>
  <div
    class="bg-bg relative w-full max-w-md scale-95 overflow-hidden text-center transition-transform duration-300"
  >
    <!-- decorative wordmark, same treatment as footer -->
    <div
      class="font-display text-brand-500/10 pointer-events-none absolute inset-x-0 bottom-0 z-0 translate-y-[28%] -skew-x-6 text-center text-8xl leading-[0.8] uppercase select-none"
      aria-hidden="true"
    >
      FLAGMINGOS
    </div>

    <div class="relative z-10 p-6 pt-8 sm:p-8 sm:pt-10">
      <!-- {
        football && variant === 'success' ? (
          <Football class={`mx-auto mb-6 h-12 w-12 ${current.color}`} />
        ) : (
          <div
            class={`mx-auto mb-6 flex h-16 w-16 items-center justify-center ${current.bg} text-white`}
          >
            {variant === 'error' ? <X class="h-8 w-8" /> : <Check class="h-8 w-8" />}
          </div>
        )
      } -->

      <p
        class="text-brand-500 mb-3 flex items-center justify-center gap-2 font-mono text-xs tracking-[0.2em] uppercase"
      >
        <span class="bg-brand-500/50 h-px w-4" aria-hidden="true"></span>
        {eyebrow || current.defaultEyebrow}
        <span class="bg-brand-500/50 h-px w-4" aria-hidden="true"></span>
      </p>

      <h3 id={titleId} class="font-display text-ink text-3xl leading-none uppercase">
        {title || current.defaultTitle}
      </h3>

      <p id={contentId} class="text-ink-soft mt-4 text-sm leading-relaxed">
        <slot />
      </p>
      <div class="mt-6 flex flex-col items-center gap-3">
        <slot name="actions" />
        <button
          data-modal-close={id}
          class="group border-brand-500 bg-brand-500 hover:bg-bg hover:text-brand-500 mt-8 inline-flex items-center justify-center gap-2 border-2 px-8 py-3.5 text-sm font-bold tracking-wide text-white uppercase transition-all"
        >
          {button}
        </button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ id }}>
  const modal = document.getElementById(id)
  const closeBtn = document.querySelector(`[data-modal-close="${id}"]`)

  function openModal() {
    modal?.classList.remove('hidden', 'opacity-0')
    modal?.classList.add('flex', 'opacity-100')
  }
  function closeModal() {
    modal?.classList.add('hidden', 'opacity-0')
    modal?.classList.remove('flex', 'opacity-100')
  }

  closeBtn?.addEventListener('click', closeModal)
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()
  })
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal()
  })
  document.addEventListener(`open-modal:${id}`, openModal)
</script>
