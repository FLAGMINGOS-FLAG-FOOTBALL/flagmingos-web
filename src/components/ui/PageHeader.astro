---
interface Props {
  eyebrow: string
  title: string
  highlight?: string
  subtitle?: string
  break?: boolean
  tags?: string[]
  cta?: string
}

const { eyebrow, title, highlight, subtitle, tags, cta } = Astro.props
const linebreak = Astro.props.break ?? true
---

<section class="bg-bg relative overflow-hidden pt-14 pb-10 md:pt-20 md:pb-14">
  <div class="absolute inset-0 hero-stripes opacity-90 pointer-events-none">
  </div>
  <div class="relative mx-auto max-w-205 px-5 md:px-10 text-center">
    <div
      class="inline-flex items-center gap-2 font-mono text-xs md:text-[13px] font-bold text-white bg-ink px-2.5 py-1.5 mb-6"
    >
      {eyebrow}
    </div>
    <h1
      class="font-display uppercase leading-[0.9] text-[clamp(38px,9vw,84px)]"
    >
      {title}
      <br class={`${linebreak ? '' : 'hidden'} `} />
      {highlight && <span class="text-brand-500">{highlight}</span>}
    </h1>
    {
      subtitle && (
        <p class="max-w-155 mx-auto mt-6 text-base md:text-lg leading-relaxed text-ink-soft">
          {subtitle}
        </p>
      )
    }
    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap justify-center gap-2.5 mt-8">
          {tags.map((tag) => (
            <span class="font-mono text-[11px] font-semibold uppercase tracking-wide bg-brand-100 text-brand-700 px-3 py-1.5">
              {tag}
            </span>
          ))}
        </div>
      )
    }
    {
      cta && (
        <p class="text-sm text-ink-soft mt-8" set:html={cta} />
      )
    }
  </div>
</section>
