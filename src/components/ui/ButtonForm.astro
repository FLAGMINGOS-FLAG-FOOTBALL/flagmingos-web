---
import RightArrow from '@lucide/astro/icons/arrow-right'

interface ButtonFormProps {
  type?: 'button' | 'submit' | 'reset'
  id?: string
  icon?: string
}

const { type = 'button', id, icon } = Astro.props as ButtonFormProps
---

<button
  type={type || 'button'}
  class={'group relative w-full overflow-hidden inline-flex justify-center items-center gap-3 border-2 border-brand-500 bg-brand-500 text-white font-bold uppercase tracking-wide text-sm px-6 py-4 transition-all duration-300 hover:text-brand-500 disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer'}
>
  <span class="relative z-10 transition-transform duration-300" id={id}>
    <slot />
  </span>

  {icon === 'arrow-right' && (
    <RightArrow
      class="relative z-10 w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"
      aria-hidden="true"
    />
  )}

  <span
    class="absolute inset-0 bg-white -translate-x-full transition-transform duration-300 group-hover:translate-x-0"
  ></span>
</button>
