---
<button
  id="back-to-top"
  aria-label="Back to top"
  class="fixed bottom-20 right-5 md:bottom-8 md:right-8 z-40 w-11 h-11 md:w-12 md:h-12 bg-ink text-white flex items-center justify-center shadow-lg opacity-0 translate-y-3 pointer-events-none transition-all duration-300 hover:bg-brand-500"
>
  <span aria-hidden="true" class="text-lg leading-none">&uarr;</span>
</button>

<script>
  const btn = document.getElementById('back-to-top');

  function toggle() {
    if (!btn) return;
    if (window.scrollY > 480) {
      btn.classList.remove('opacity-0', 'translate-y-3', 'pointer-events-none');
    } else {
      btn.classList.add('opacity-0', 'translate-y-3', 'pointer-events-none');
    }
  }

  window.addEventListener('scroll', toggle, { passive: true });
  toggle();

  btn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
