---
import Mail from '@lucide/astro/icons/mail'
import Phone from '@lucide/astro/icons/phone'
import SectionTitle from './ui/SectionTitle.astro'
import Instagram from './icons/Instagram.astro'

import ButtonForm from './ui/ButtonForm.astro'
import ModalForm from './ui/ModalForm.astro'

import Paragraph from './ui/Paragraph.astro'
import { email, instagram, phone } from '../params.json'

const contact_options = [
  { label: "Rejoindre l'équipe", value: 'joining' },
  { label: 'Partenariat / Sponsoring', value: 'sponsorship' },
  { label: 'Media / Presse', value: 'media' },
  { label: 'Autre', value: 'other' },
]

const team_section = [
  { label: 'Équipe Compétition (Mixte dès 17 ans)', value: 'competition' },
  { label: 'Équipe Féminine', value: 'feminine' },
  { label: 'Équipe Jeunes (8-16 ans)', value: 'youth' },
  { label: 'Équipe Loisir (Mixte dès 17 ans)', value: 'loisir' },
]

const contact_link = [
  { label: 'Adresse mail', value: email, icon: Mail, link: `mailto:${email}` },
  {
    label: 'Instagram',
    value: instagram,
    icon: Instagram,
    link: `https://instagram.com/${instagram}`,
  },
]
---

<section id="contact" class="py-16 md:py-27.5">
  <div class="mx-auto grid max-w-295 grid-cols-1 gap-9 px-5 md:grid-cols-2 md:gap-20 md:px-10">
    <div>
      <SectionTitle title="Contactez-nous" tagline="Get in touch" />
      <Paragraph class="max-w-105">
        Une question sur les entraînements, un partenariat, la presse ou juste envie de nous
        rejoindre — écris-nous, on répond sous 24h.
      </Paragraph>
      <div class="mt-3 space-y-6 p-5 md:p-6">
        {
          contact_link.map((link) => (
            <div class="flex items-start gap-4">
              <div class="bg-brand-100 text-brand-700 p-3">
                <link.icon class="h-6 w-6" />
              </div>
              <div>
                <span class="text-soft-ink block font-mono text-[11px] tracking-wide uppercase">
                  {link.label}
                </span>
                <a
                  href={link.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-md text-ink hover:text-brand-500 font-semibold transition-colors"
                >
                  {link.value}
                </a>
              </div>
            </div>
          ))
        }
      </div>

      <div id="phone-card" class="status-bg border-line mt-3 border p-5 md:p-6">
        <div class="mb-5 flex items-center justify-between">
          <span class="text-ink-soft font-mono text-[11px] tracking-widest uppercase">
            Permanence téléphonique
          </span>

          <span
            id="phone-status"
            class="inline-flex items-center gap-2 px-3 py-1 text-[11px] font-bold tracking-widest uppercase"
          >
            <span class="status-dot h-2 w-2 rounded-full"></span>
            <span class="status-text"></span>
          </span>
        </div>

        <a
          href={`tel:${phone}`}
          class="text-md text-ink hover:text-brand-500 flex items-center gap-3 font-semibold transition-colors"
        >
          <span class="bg-brand-100 text-brand-700 flex items-center justify-center p-3">
            <Phone class="h-6 w-6" />
          </span>
          {phone}
        </a>

        <div class="text-ink-soft mt-4 text-sm">
          <p class="text-ink">Du lundi au vendredi de 10h00 à 18h30</p>
        </div>

        <p class="border-line text-ink-soft mt-4 border-t pt-4 text-xs leading-relaxed">
          En dehors de ces horaires, contactez-nous par email ou via nos réseaux sociaux.
        </p>
      </div>
    </div>

    <div class="border-line flex h-full flex-col border bg-white p-6 md:p-8">
      <form
        id="contact-form"
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="flex flex-1 flex-col space-y-5"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>
            Don't fill this out if you're human:
            <input name="bot-field" />
          </label>
        </p>
        <div>
          <label
            for="name"
            class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >Nom complet</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
            placeholder="Jeanne Dupont"
          />
        </div>

        <div>
          <label
            for="email"
            class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >Adresse email</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
            placeholder="jeanne.dupont@email.com"
          />
        </div>

        <div>
          <label
            for="reason"
            class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >Je me renseigne sur</label
          >
          <select
            id="reason"
            name="reason"
            required
            class="border-line focus:border-brand-500 w-full border-2 bg-white px-3.5 py-2.5 text-sm transition-colors outline-none"
          >
            <option value="" selected disabled>Choisissez un motif</option>
            {contact_options.map((option) => <option value={option.value}>{option.label}</option>)}
          </select>
        </div>

        <div id="team-field" class="hidden">
          <label
            for="team"
            class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
          >
            Quelle équipe ?
          </label>

          <select
            id="team"
            name="team"
            class="border-line focus:border-brand-500 w-full border-2 bg-white px-3.5 py-2.5 text-sm transition-colors outline-none"
          >
            <option value="" selected disabled>Choisissez une équipe</option>

            {team_section.map((team) => <option value={team.value}>{team.label}</option>)}
          </select>
        </div>

        <label
          for="object"
          class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
          >Objet du message</label
        >
        <input
          type="text"
          id="object"
          name="object"
          class="border-line focus:border-brand-500 w-full border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
          placeholder="Objet du message"
        />

        <div>
          <label
            for="message"
            class="text-ink-soft mb-1.5 block font-mono text-[11px] tracking-wide uppercase"
            >Message</label
          >
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            class="border-line focus:border-brand-500 w-full resize-none border-2 px-3.5 py-2.5 text-sm transition-colors outline-none"
            placeholder="Dites-nous en plus..."></textarea>
        </div>
        <!-- <p class="font-mono text-[11px] text-ink-soft">
          En envoyant ce formulaire, vous acceptez que vos données soient
          utilisées uniquement pour répondre à votre demande.
        </p> -->
        <label class="flex cursor-pointer items-start gap-2.5 text-sm">
          <input type="checkbox" name="privacy-consent" required class="accent-brand-500 mt-1" />

          <span>
            J'accepte que mes données soient utilisées uniquement afin de répondre à ma demande.
            <a href="/mentions-legales#donnees-personnelles" class="hover:text-brand-700 underline">
              En savoir plus</a
            >.
          </span>
        </label>

        <!-- <div data-netlify-recaptcha="true"></div> -->
        <ButtonForm type="submit" class="w-full" id="submit-button" icon="arrow-right">
          Envoyer ma demande
        </ButtonForm>
        <!-- <button
          type="submit"
          class="w-full inline-flex justify-center items-center gap-2 border-2 border-brand-500 bg-brand-500 text-white font-extrabold text-sm px-6 py-3.5 hover:bg-brand-700 hover:border-brand-700 transition-all disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span id="submit-label">Envoyer le message</span>
        </button> -->
      </form>

      <p id="form-status" class="hidden text-center text-sm" role="status"></p>
    </div>
    <ModalForm id="success-modal" football>
      Votre message est dans nos mains. <br />On revient vers vous rapidement.
    </ModalForm>
    <ModalForm id="error-modal" variant="error" title="Oups !">
      Une erreur est survenue lors de l'envoi du formulaire.<br />Merci de réessayer plus tard ou de
      nous contacter via un autre moyen.
    </ModalForm>
  </div>

  <script>
    const reasonSelect = document.getElementById('reason')
    const teamField = document.getElementById('team-field')
    const teamSelect = document.getElementById('team')

    function updateTeamField() {
      const show = reasonSelect.value === 'joining'

      teamField.classList.toggle('hidden', !show)

      if (show) {
        teamSelect.required = true
      } else {
        teamSelect.required = false
        teamSelect.value = ''
      }
    }

    updateTeamField()

    reasonSelect.addEventListener('change', updateTeamField)
  </script>

  <script>
    const hour = new Date().getHours()

    const day = new Date().getDay()

    const isOpen = day >= 1 && day <= 5 && hour >= 10 && hour < 18.5

    const card = document.getElementById('phone-card')
    const badge = document.getElementById('phone-status')
    const text = badge?.querySelector('.status-text')

    if (isOpen) {
      badge?.classList.add('bg-green-50', 'text-green-700')
      badge?.querySelector('.status-dot')?.classList.add('bg-green-500')
      card?.classList.add('bg-white')
      if (text) text.textContent = 'Disponible'
    } else {
      badge?.classList.add('bg-gray-100', 'text-gray-500')
      badge?.querySelector('.status-dot')?.classList.add('bg-gray-400')
      card?.classList.add('bg-bg')
      if (text) text.textContent = 'Indisponible'
    }
  </script>

  <script>
    import { submitForm } from '../lib/form'
    submitForm('contact-form', 'success-modal', 'error-modal')
  </script>
</section>
