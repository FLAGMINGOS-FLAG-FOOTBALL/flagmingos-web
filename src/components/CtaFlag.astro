---
import SectionTitle from './ui/SectionTitle.astro'
import RightArrow from '@lucide/astro/icons/arrow-right'
import Button from './ui/Button.astro'
import Paragraph from './ui/Paragraph.astro'
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right'
import Shield from '@lucide/astro/icons/shield'
import Users from '@lucide/astro/icons/users'
import Brain from '@lucide/astro/icons/brain'
import Sparkles from '@lucide/astro/icons/sparkles'
const facts = [
  { n: '5v5', l: 'Format' },
  { n: '0', l: 'Contact' },
  { n: '100%', l: 'Mixte' },
  { n: '7 ans', l: 'Âge min.' },
]

const atouts = [
  {
    icon: Shield,
    title: 'Sans contact',
    text: 'On retire un flag à la ceinture plutôt que de plaquer : l\u2019intensité du foot US, sans le risque de blessure.',
  },
  {
    icon: Users,
    title: '100% mixte',
    text: 'Hommes et femmes jouent ensemble, sur le même terrain, dans la même équipe.',
  },
  {
    icon: Brain,
    title: 'Stratégique',
    text: 'Un temps mort entre chaque action pour construire son jeu : la tactique compte autant que l\u2019athlétisme.',
  },
  {
    icon: Sparkles,
    title: 'Accessible dès 7 ans',
    text: 'Aucune expérience requise. La majorité des licenciés découvrent le flag en arrivant au club.',
  },
]
---
<section class="bg-white text-ink border-line scroll-mt-32 border-t border-b py-14 md:py-20">
  <div class="mx-auto max-w-295 px-5 md:px-10">
    <SectionTitle title="PREMIERS PAS" tagline="Découvre le futur sport olympique" />
    <p class="text-ink-soft max-w-180 text-sm leading-relaxed md:text-base">
      Le flag football est une variante du football américain, mais sans plaquage : on retire un
      flag à la ceinture au lieu de plaquer le porteur du ballon. Résultat : un sport rapide et
      stratégique, ouvert à toutes et à tous.
    </p>

    <div class="bg-line mt-10 grid grid-cols-1 gap-px sm:grid-cols-2 lg:grid-cols-4">
      {
        atouts.map((a) => (
          <div class="bg-white p-6">
            <div class="font-display mt-4 flex items-center gap-2 text-lg uppercase">
              <span class="inline-flex items-center justify-center">
                <a.icon class="text-brand-500 h-6 w-6" />
              </span>
              {a.title}
            </div>
            <p class="text-ink-soft mt-2 text-sm leading-relaxed">{a.text}</p>
          </div>
        ))
      }
    </div>

    <Button href="/flag-football" variant="text" class="mt-3" size="text">
      Découvrir le flag football
      <RightArrow class="h-4 w-4" />
    </Button>
  </div>
</section>
