---
import SectionTitle from './ui/SectionTitle.astro'
import RightArrow from '@lucide/astro/icons/arrow-right'
import Button from './ui/Button.astro'
import Paragraph from './ui/Paragraph.astro'
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right'
import Shield from '@lucide/astro/icons/shield'
import Users from '@lucide/astro/icons/users'
import Brain from '@lucide/astro/icons/brain'
import Sparkles from '@lucide/astro/icons/sparkles'
const facts = [
  { n: '5v5', l: 'Format' },
  { n: '0', l: 'Contact' },
  { n: '100%', l: 'Mixte' },
  { n: '7 ans', l: 'Âge min.' },
]

const atouts = [
  {
    icon: Shield,
    title: 'Sans contact',
    text: 'On retire un flag à la ceinture plutôt que de plaquer — l\u2019intensité du foot US, sans le risque de blessure.',
  },
  {
    icon: Users,
    title: '100% mixte',
    text: 'Hommes et femmes jouent ensemble, sur le même terrain, dans la même équipe.',
  },
  {
    icon: Brain,
    title: 'Stratégique',
    text: 'Un temps mort entre chaque action pour construire son jeu — la tactique compte autant que l\u2019athlétisme.',
  },
  {
    icon: Sparkles,
    title: 'Accessible dès 7 ans',
    text: 'Aucune expérience requise. La majorité des licenciés découvrent le flag en arrivant au club.',
  },
]
---

