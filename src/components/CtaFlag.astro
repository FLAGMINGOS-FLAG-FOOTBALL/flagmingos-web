---
import SectionTitle from './ui/SectionTitle.astro'
import RightArrow from '@lucide/astro/icons/arrow-right'
import Button from './ui/Button.astro'
import Paragraph from './ui/Paragraph.astro'

const facts = [
  { n: '5v5', l: 'Format' },
  { n: '0', l: 'Contact' },
  { n: '100%', l: 'Mixte' },
  { n: '7 ans', l: 'Âge min.' },
]
---

<section class="py-10 md:py-12 border-b border-t border-line bg-bg">
  <div class="mx-auto max-w-295 px-5 md:px-10">
    <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-10">
      <div class="flex-1">
        <SectionTitle
          title="NEW TO FLAG FOOTBALL?"
          tagline="DÉCOUVREZ LE FUTUR SPORT OLYMPIQUE DE 2028"
        />
        <Paragraph class="max-w-130">
          Une variante du football américain, mais sans plaquage : on retire un
          flag à la ceinture au lieu de bloquer le porteur. Rapide, stratégique,
          et accessible à toutes et tous.
        </Paragraph>
        <Button href="/flag-football" variant="text" class="mt-3" size="text">
          Découvrir les règles
          <RightArrow class="w-4 h-4" />
        </Button>
      </div>

      <div class="grid grid-cols-4 gap-4 md:gap-6 shrink-0">
        {
          facts.map((f) => (
            <div class="text-center">
              <div class="font-mono text-2xl md:text-3xl font-bold text-brand-500">
                {f.n}
              </div>
              <div class="text-[10px] md:text-[11px] uppercase tracking-wide text-ink-soft mt-1">
                {f.l}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
